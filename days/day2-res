# 3. Хранение оценок слушателей по предметам
DELETE /day2-student-grades?ignore_unavailable=true

PUT /day2-student-grades
{
  "mappings": {
    "properties": {
      "student_name": {
        "type": "keyword"
      },
      "subject": {
        "type": "keyword"
      },
      "grade": {
        "type": "byte"
      },
      "graded_at": {
        "type": "date",
        "format": "yyyy-MM-dd"
      },
      "comment": {
        "type": "text",
        "analyzer": "russian"
      }
    }
  }
}

