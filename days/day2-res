# Все хорошисты по заданному предмету, например по математике
GET /day2-student-grades/_search
{
  "_source": [
    "student_name",
    "subject",
    "grade",
    "graded_at"
  ],
  "query": {
    "bool": {
      "must": [
        {
          "term": {
            "subject": "Математика"
          }
        },
        {
          "term": {
            "grade": 4
          }
        }
      ]
    }
  },
  "sort": [
    {
      "student_name": "asc"
    },
    {
      "graded_at": "asc"
    }
  ]
}

# Все оценки, выставленные в феврале 2021 года
GET /day2-student-grades/_search
{
  "_source": [
    "student_name",
    "subject",
    "grade",
    "graded_at"
  ],
  "query": {
    "range": {
      "graded_at": {
        "gte": "2021-02-01",
        "lt": "2021-03-01"
      }
    }
  },
  "sort": [
    {
      "graded_at": "asc"
    },
    {
      "student_name": "asc"
    }
  ]
}
