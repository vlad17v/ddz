DELETE /day2-text-demo?ignore_unavailable=true

PUT /day2-text-demo
{
  "settings": {
    "analysis": {
      "char_filter": {
        "grade_to_text": {
          "type": "mapping",
          "mappings": [
            "2 => неудовлетворительно",
            "3 => удовлетворительно",
            "4 => хорошо",
            "5 => отлично"
          ]
        }
      },
      "filter": {
        "russian_stop_with_ivanov": {
          "type": "stop",
          "ignore_case": true,
          "stopwords": [
            "_russian_",
            "иванов"
          ]
        }
      },
      "analyzer": {
        "russian_grade_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "char_filter": [
            "grade_to_text"
          ],
          "filter": [
            "lowercase",
            "russian_stop_with_ivanov"
          ]
        }
      }
    }
  }
}

GET /day2-text-demo/_analyze
{
  "analyzer": "russian_grade_analyzer",
  "text": [
    "Иванов получил 5 по литературе, а Петров 4 по истории.",
    "Сегодня Иванов пересдал 2 по физике на 3."
  ]
}

